# Upstream provider keys — set either or both; two providers enables cross-provider failover
GATEWAY_ANTHROPIC_API_KEY=
GATEWAY_OPENAI_API_KEY=

# Client API keys accepted by the gateway (JSON: key -> requests/minute)
GATEWAY_CLIENT_KEYS={"demo-key": 60}

# Per-client spend caps in USD (JSON: key -> cap). Clients absent here are uncapped.
GATEWAY_CLIENT_BUDGETS={}
# off | soft (flag via X-Budget-Status header) | hard (402 once over cap)
GATEWAY_BUDGET_ENFORCEMENT=soft

# Run fully offline against the mock provider
GATEWAY_MOCK_MODE=false
